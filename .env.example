DATABASE_URL="file:./dev.db"
JWT_SECRET="troque-este-segredo-em-producao-bilyvet"

# Asaas - cobrancas e assinaturas
# Producao:
ASAAS_API_URL="https://api.asaas.com/v3"
# Sandbox (para testes): https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=""
# Token que sera enviado no header asaas-access-token do webhook (configurado no painel do Asaas)
ASAAS_WEBHOOK_TOKEN=""

# Resend - envio de email transacional (definicao/recuperacao de senha)
# Crie conta em https://resend.com, gere API key em /api-keys e cole abaixo
RESEND_API_KEY=""
# Remetente. Sem dominio verificado, use o sandbox: "BilyVet <onboarding@resend.dev>"
RESEND_FROM="BilyVet <onboarding@resend.dev>"

# URL publica da aplicacao (usado para montar links em emails)
# Em producao: https://bilyvet.com.br - em dev pode deixar vazio (detectado pelo Request)
APP_URL=""
