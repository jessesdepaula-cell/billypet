// BilyVet - Schema Prisma
// Modela todas as entidades do sistema: cadastros, atendimento,
// agenda, internacao, vendas, financeiro, estoque, fidelidade, etc.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ============================================================
// AUTENTICACAO / PERFIS / UNIDADES
// ============================================================

model Unit {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  cnpj      String?
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  appointments       Appointment[]
  sales              Sale[]
  cashRegisters      CashRegister[]
  stocks             Stock[]
  accountsPayable    AccountPayable[]
  accountsReceivable AccountReceivable[]
  hospitalizations   Hospitalization[]

  @@index([tenantId])
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String // SUPER_ADMIN | ADMIN | GESTOR | VETERINARIO | RECEPCAO | FINANCEIRO | ESTOQUE | BANHO_TOSA | VENDEDOR
  permissions  String? // JSON array de slugs de modulo liberados. Null = usar padrao do role.
  isActive     Boolean  @default(true)
  unitId       String?
  unit         Unit?    @relation(fields: [unitId], references: [id])
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointmentsAsVet Appointment[]     @relation("VetAppointments")
  medicalRecords    MedicalRecord[]
  hospitalizations  Hospitalization[]
  salesAsSeller     Sale[]
  cashRegisters     CashRegister[]
  commissions       Commission[]
  auditLogs         AuditLog[]
  supportTickets    SupportTicket[]
  collaborator      Collaborator?
}

// ============================================================
// SAAS - TENANTS (CLIENTES ASSINANTES) E ASSINATURAS ASAAS
// ============================================================

model Tenant {
  id              String    @id @default(cuid())
  companyName     String // Razao social / nome da clinica
  tradeName       String? // Nome fantasia
  cnpj            String?   @unique
  email           String
  phone           String?
  responsibleName String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  status          String    @default("TRIAL") // TRIAL, ACTIVE, PAST_DUE, SUSPENDED, CANCELED
  asaasCustomerId String?   @unique
  notes           String?
  trialEndsAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users              User[]
  subscriptions      Subscription[]
  payments           SubscriptionPayment[]
  units              Unit[]
  tutors             Tutor[]
  products           Product[]
  productCategories  ProductCategory[]
  suppliers          Supplier[]
  services           Service[]
  kits               Kit[]
  paymentMethods     PaymentMethod[]
  cardMachines       CardMachine[]
  whatsappConnection WhatsappConnection?
  whatsappContacts   WhatsappContact[]
  whatsappMessages   WhatsappMessage[]
}

model Subscription {
  id                  String    @id @default(cuid())
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asaasSubscriptionId String?   @unique
  plan                String    @default("PRO") // PRO (R$197/mes) - extensivel
  value               Float     @default(197)
  cycle               String    @default("MONTHLY") // MONTHLY, YEARLY
  billingType         String    @default("UNDEFINED") // BOLETO, CREDIT_CARD, PIX, UNDEFINED
  status              String    @default("PENDING") // PENDING, ACTIVE, OVERDUE, CANCELED, EXPIRED
  nextDueDate         DateTime?
  startedAt           DateTime  @default(now())
  canceledAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  payments SubscriptionPayment[]
}

model SubscriptionPayment {
  id             String        @id @default(cuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  asaasPaymentId String?       @unique
  value          Float
  netValue       Float?
  status         String // PENDING, RECEIVED, CONFIRMED, OVERDUE, REFUNDED, CANCELED
  billingType    String? // BOLETO, CREDIT_CARD, PIX
  dueDate        DateTime
  paidAt         DateTime?
  invoiceUrl     String?
  bankSlipUrl    String?
  pixPayload     String?
  description    String?
  rawEvent       String? // payload bruto do webhook (debug)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model AsaasWebhookEvent {
  id        String   @id @default(cuid())
  event     String
  payload   String // JSON cru
  processed Boolean  @default(false)
  error     String?
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

// ============================================================
// CADASTROS PRINCIPAIS
// ============================================================

model Tutor {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  document      String? // CPF/CNPJ
  phone         String?
  whatsapp      String?
  email         String?
  address       String?
  notes         String?
  loyaltyPoints Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pets                Pet[]
  appointments        Appointment[]
  sales               Sale[]
  accountsReceivable  AccountReceivable[]
  servicePackages     ServicePackage[]
  loyaltyTransactions LoyaltyTransaction[]

  @@index([tenantId])
}

model Pet {
  id           String    @id @default(cuid())
  name         String
  species      String // Cao, Gato, Ave, Roedor, Reptil, Outro
  breed        String?
  sex          String? // M, F
  neutered     Boolean? // true=castrado, false=fertil, null=nao informado
  birthDate    DateTime?
  weightKg     Float?
  color        String?
  microchip    String?
  notes        String?
  medicalAlert String?
  isActive     Boolean   @default(true)
  tutorId      String
  tutor        Tutor     @relation(fields: [tutorId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  appointments     Appointment[]
  medicalRecords   MedicalRecord[]
  vaccines         Vaccine[]
  exams            Exam[]
  hospitalizations Hospitalization[]
  servicePackages  ServicePackage[]
  deceased         Boolean           @default(false)
  deceasedAt       DateTime?
  attachments      PetAttachment[]
  protocols        Protocol[]
  weightRecords    WeightRecord[]
}

model WeightRecord {
  id            String   @id @default(cuid())
  petId         String
  pet           Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  weightKg      Float
  source        String   @default("MANUAL") // MANUAL, ATENDIMENTO
  appointmentId String?
  note          String?
  createdAt     DateTime @default(now())

  @@index([petId])
}

// ============================================================
// PRODUTOS / ESTOQUE
// ============================================================

model ProductCategory {
  id       String    @id @default(cuid())
  tenantId String
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  products Product[]

  @@index([tenantId])
}

model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  document  String?
  phone     String?
  email     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  products        Product[]
  accountsPayable AccountPayable[]

  @@index([tenantId])
}

model Product {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  sku          String?
  barcode      String?
  brand        String?
  categoryId   String?
  category     ProductCategory? @relation(fields: [categoryId], references: [id])
  supplierId   String?
  supplier     Supplier?        @relation(fields: [supplierId], references: [id])
  costPrice    Float            @default(0)
  salePrice    Float            @default(0)
  minStock     Int              @default(0)
  unit         String           @default("UN") // UN, KG, L, ML, CX
  controlByLot Boolean          @default(false)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  stocks    Stock[]
  movements StockMovement[]
  saleItems SaleItem[]
  kitItems  KitItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
}

model Stock {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id])
  unitId    String
  unit      Unit      @relation(fields: [unitId], references: [id])
  quantity  Float     @default(0)
  lot       String?
  expiresAt DateTime?

  @@unique([productId, unitId, lot])
}

model StockMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  unitId    String
  quantity  Float
  type      String // ENTRADA, SAIDA_VENDA, SAIDA_USO, TRANSFERENCIA, PERDA, AJUSTE, DEVOLUCAO, XML
  reason    String?
  reference String? // venda id, atendimento id, etc.
  createdAt DateTime @default(now())
}

model Kit {
  id       String    @id @default(cuid())
  tenantId String
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  price    Float     @default(0)
  isActive Boolean   @default(true)
  items    KitItem[]

  @@index([tenantId])
}

model KitItem {
  id        String  @id @default(cuid())
  kitId     String
  kit       Kit     @relation(fields: [kitId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Float
}

// ============================================================
// SERVICOS / PACOTES / COMISSAO
// ============================================================

model Service {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  category        String? // Banho, Tosa, Consulta, Exame, Cirurgia, Outro
  durationMinutes Int      @default(30)
  price           Float    @default(0)
  commissionPct   Float    @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  appointmentServices AppointmentService[]
  saleItems           SaleItem[]
  packageServices     ServicePackageItem[]
  collaborators       CollaboratorService[]

  @@index([tenantId])
}

model ServicePackage {
  id            String    @id @default(cuid())
  name          String
  tutorId       String?
  tutor         Tutor?    @relation(fields: [tutorId], references: [id])
  petId         String?
  pet           Pet?      @relation(fields: [petId], references: [id])
  totalQuantity Int // servicos contratados
  usedQuantity  Int       @default(0)
  price         Float     @default(0)
  validUntil    DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  services ServicePackageItem[]
  usages   PackageUsage[]
}

model ServicePackageItem {
  id        String         @id @default(cuid())
  packageId String
  package   ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service        @relation(fields: [serviceId], references: [id])
  quantity  Int            @default(1)
}

model PackageUsage {
  id          String         @id @default(cuid())
  packageId   String
  package     ServicePackage @relation(fields: [packageId], references: [id])
  serviceName String
  usedAt      DateTime       @default(now())
  notes       String?
}

model CommissionRule {
  id         String    @id @default(cuid())
  userId     String?
  serviceId  String?
  productId  String?
  percent    Float     @default(0)
  fixedValue Float     @default(0)
  validFrom  DateTime?
  validTo    DateTime?
  isActive   Boolean   @default(true)
}

model Commission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  reference String // sale id or appointment id
  amount    Float
  paid      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============================================================
// AGENDA / ATENDIMENTO / FICHA / RECEITUARIO
// ============================================================

model Appointment {
  id             String   @id @default(cuid())
  unitId         String
  unit           Unit     @relation(fields: [unitId], references: [id])
  tutorId        String
  tutor          Tutor    @relation(fields: [tutorId], references: [id])
  petId          String?
  pet            Pet?     @relation(fields: [petId], references: [id])
  vetId          String?
  vet            User?    @relation("VetAppointments", fields: [vetId], references: [id])
  scheduledAt    DateTime
  type           String // CONSULTA, RETORNO, BANHO_TOSA, EXAME, PROCEDIMENTO
  status         String   @default("AGENDADO") // AGENDADO, CONFIRMADO, EM_ATENDIMENTO, FINALIZADO, CANCELADO, NAO_COMPARECEU
  notes          String?
  pipelineStage  String   @default("AGUARDANDO") // AGUARDANDO, RECEPCAO, TRIAGEM, EM_CONSULTA, EXAMES, BANHO_TOSA, INTERNACAO, PAGAMENTO, FINALIZADO
  stageEnteredAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  services      AppointmentService[]
  medicalRecord MedicalRecord?
  collaborators AppointmentCollaborator[]
}

model AppointmentService {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])
  price         Float
}

model MedicalRecord {
  id              String      @id @default(cuid())
  appointmentId   String      @unique
  appointment     Appointment @relation(fields: [appointmentId], references: [id])
  petId           String
  pet             Pet         @relation(fields: [petId], references: [id])
  vetId           String
  vet             User        @relation(fields: [vetId], references: [id])
  complaint       String?
  anamnesis       String?
  physicalExam    String?
  weightKg        Float?
  diagnosis       String?
  conduct         String?
  procedures      String?
  observations    String?
  recommendReturn DateTime?
  createdAt       DateTime    @default(now())

  prescriptions Prescription[]
}

model Prescription {
  id              String        @id @default(cuid())
  medicalRecordId String
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  medication      String
  dosage          String
  frequency       String
  duration        String
  guidelines      String?
}

model Vaccine {
  id        String    @id @default(cuid())
  petId     String
  pet       Pet       @relation(fields: [petId], references: [id])
  name      String
  appliedAt DateTime
  nextDose  DateTime?
  batch     String?
  notes     String?
  createdAt DateTime  @default(now())
}

model Exam {
  id            String    @id @default(cuid())
  petId         String
  pet           Pet       @relation(fields: [petId], references: [id])
  name          String
  status        String    @default("SOLICITADO") // SOLICITADO, COLETADO, EM_ANALISE, DISPONIVEL, CANCELADO
  requestedAt   DateTime  @default(now())
  resultAt      DateTime?
  result        String?
  attachmentUrl String?
}

// ============================================================
// INTERNACAO
// ============================================================

model Hospitalization {
  id           String    @id @default(cuid())
  unitId       String
  unit         Unit      @relation(fields: [unitId], references: [id])
  petId        String
  pet          Pet       @relation(fields: [petId], references: [id])
  vetId        String
  vet          User      @relation(fields: [vetId], references: [id])
  bed          String?
  reason       String?
  status       String    @default("ATIVA") // ATIVA, ALTA, OBITO
  admittedAt   DateTime  @default(now())
  expectedAt   DateTime?
  dischargedAt DateTime?
  notes        String?

  evolutions HospitalizationEvolution[]
}

model HospitalizationEvolution {
  id                String          @id @default(cuid())
  hospitalizationId String
  hospitalization   Hospitalization @relation(fields: [hospitalizationId], references: [id], onDelete: Cascade)
  description       String
  vitals            String?
  medications       String?
  createdAt         DateTime        @default(now())
}

// ============================================================
// VENDAS / PAGAMENTOS / CAIXA
// ============================================================

model PaymentMethod {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  type     String // DINHEIRO, PIX, CREDITO, DEBITO, CONVENIO, ANTECIPADO, OUTRO
  isActive Boolean @default(true)

  payments Payment[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model CardMachine {
  id            String  @id @default(cuid())
  tenantId      String
  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  operator      String?
  debitFee      Float   @default(0)
  creditFee     Float   @default(0)
  receivingDays Int     @default(30)
  accountName   String?
  isActive      Boolean @default(true)

  @@index([tenantId])
}

model Sale {
  id        String   @id @default(cuid())
  unitId    String
  unit      Unit     @relation(fields: [unitId], references: [id])
  tutorId   String?
  tutor     Tutor?   @relation(fields: [tutorId], references: [id])
  sellerId  String?
  seller    User?    @relation(fields: [sellerId], references: [id])
  discount  Float    @default(0)
  surcharge Float    @default(0)
  total     Float    @default(0)
  status    String   @default("ABERTA") // ABERTA, FINALIZADA, CANCELADA
  notes     String?
  createdAt DateTime @default(now())

  items    SaleItem[]
  payments Payment[]
}

model SaleItem {
  id          String   @id @default(cuid())
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])
  description String
  quantity    Float
  unitPrice   Float
  total       Float
}

model Payment {
  id              String        @id @default(cuid())
  saleId          String?
  sale            Sale?         @relation(fields: [saleId], references: [id])
  paymentMethodId String
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  amount          Float
  installments    Int           @default(1)
  paidAt          DateTime      @default(now())
}

model CashRegister {
  id         String    @id @default(cuid())
  unitId     String
  unit       Unit      @relation(fields: [unitId], references: [id])
  openedById String
  openedBy   User      @relation(fields: [openedById], references: [id])
  openedAt   DateTime  @default(now())
  closedAt   DateTime?
  openValue  Float     @default(0)
  closeValue Float?
  status     String    @default("ABERTO") // ABERTO, FECHADO

  transactions FinancialTransaction[]
}

model FinancialTransaction {
  id             String        @id @default(cuid())
  cashRegisterId String?
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id])
  type           String // ENTRADA, SAIDA, SANGRIA, SUPRIMENTO
  category       String?
  description    String
  amount         Float
  createdAt      DateTime      @default(now())
}

// ============================================================
// CONTAS A PAGAR / RECEBER
// ============================================================

model AccountReceivable {
  id          String    @id @default(cuid())
  unitId      String
  unit        Unit      @relation(fields: [unitId], references: [id])
  tutorId     String?
  tutor       Tutor?    @relation(fields: [tutorId], references: [id])
  description String
  amount      Float
  dueDate     DateTime
  paidAt      DateTime?
  paidAmount  Float?
  status      String    @default("ABERTA") // ABERTA, PAGA, PARCIAL, VENCIDA, CANCELADA
  installment String? // 1/3
  saleId      String?
  createdAt   DateTime  @default(now())
}

model AccountPayable {
  id          String    @id @default(cuid())
  unitId      String
  unit        Unit      @relation(fields: [unitId], references: [id])
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  category    String?
  description String
  amount      Float
  dueDate     DateTime
  paidAt      DateTime?
  status      String    @default("ABERTA") // ABERTA, PAGA, VENCIDA, CANCELADA
  recurring   Boolean   @default(false)
  costCenter  String?
  createdAt   DateTime  @default(now())
}

// ============================================================
// FIDELIDADE / DOCUMENTOS / SUPORTE / AUDITORIA
// ============================================================

model LoyaltyTransaction {
  id        String   @id @default(cuid())
  tutorId   String
  tutor     Tutor    @relation(fields: [tutorId], references: [id])
  points    Int // positivo = acumulo, negativo = resgate
  reason    String
  createdAt DateTime @default(now())
}

model Document {
  id        String    @id @default(cuid())
  tenantId  String
  type      String // TERMO_RESPONSABILIDADE, TERMO_INTERNACAO, AUTORIZACAO, RECIBO, ORCAMENTO, RECEITA
  title     String
  content   String
  tutorId   String?
  petId     String?
  signedAt  DateTime?
  signedBy  String?
  createdAt DateTime  @default(now())

  @@index([tenantId])
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  subject   String
  body      String
  status    String   @default("ABERTO") // ABERTO, EM_ATENDIMENTO, RESOLVIDO, FECHADO
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

// ============================================================
// NOVAS ENTIDADES
// ============================================================

model AppointmentStatus {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  color     String   @default("#cbd5e1")
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([tenantId, name])
}

model Collaborator {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  role      String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  services     CollaboratorService[]
  appointments AppointmentCollaborator[]
  userId       String?                   @unique
  user         User?                     @relation(fields: [userId], references: [id])
}

model CollaboratorService {
  id             String       @id @default(cuid())
  collaboratorId String
  collaborator   Collaborator @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  serviceId      String
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  isResponsible  Boolean      @default(false)

  @@unique([collaboratorId, serviceId])
}

model AppointmentCollaborator {
  id             String       @id @default(cuid())
  appointmentId  String
  appointment    Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  collaboratorId String
  collaborator   Collaborator @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, collaboratorId])
}

model Protocol {
  id        String                @id @default(cuid())
  tenantId  String
  petId     String
  pet       Pet                   @relation(fields: [petId], references: [id], onDelete: Cascade)
  name      String
  type      String
  startDate DateTime
  notes     String?
  status    String                @default("ATIVO") // ATIVO, CONCLUIDO, CANCELADO
  createdAt DateTime              @default(now())
  updatedAt DateTime              @default(now()) @updatedAt
  doses     ProtocolApplication[]
}

model ProtocolApplication {
  id         String    @id @default(cuid())
  protocolId String
  protocol   Protocol  @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  dueDate    DateTime
  appliedAt  DateTime?
  notes      String?
  status     String    @default("PENDENTE") // PENDENTE, APLICADO, ATRASADO, CANCELADO
}

model ProtocolTemplate {
  id        String                 @id @default(cuid())
  tenantId  String
  name      String
  type      String
  notes     String?
  isActive  Boolean                @default(true)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @default(now()) @updatedAt
  doses     ProtocolTemplateDose[]
}

model ProtocolTemplateDose {
  id         String           @id @default(cuid())
  templateId String
  template   ProtocolTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name       String
  daysOffset Int
}

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  title     String
  message   String
  type      String    @default("PROTOCOL_REMINDER")
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())
  dueDate   DateTime?
  link      String?
}

model PetAttachment {
  id        String   @id @default(cuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  name      String
  mimeType  String
  sizeBytes Int
  fileData  String? // legado: base64 (anexos antigos pre-Vercel-Blob)
  url       String? // novo: URL publica do Vercel Blob
  createdAt DateTime @default(now())
}

// ============================================================
// WHATSAPP + IA (assistente por WhatsApp + inbox interno)
// Uma instancia Evolution isolada por assinatura (tenant): `bp-<tenantId>`.
// ============================================================

// Conexao WhatsApp da assinatura. Servidor/chave Evolution sao da plataforma;
// o assinante so escaneia o QR. Guarda os prompts editaveis da IA.
model WhatsappConnection {
  id                String    @id @default(cuid())
  tenantId          String    @unique
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instanceName      String    @unique // bp-<tenantId>
  status            String    @default("DISCONNECTED") // DISCONNECTED, CONNECTING, CONNECTED
  connectedNumber   String?
  // IA ligada para mensagens de CLIENTES (numeros nao cadastrados).
  aiClientEnabled   Boolean   @default(true)
  // IA ligada para OPERADORES (numeros cadastrados que alimentam o sistema).
  aiOperatorEnabled Boolean   @default(true)
  // Prompt extra do modo OPERADOR (dono/equipe alimentando o sistema).
  operatorPrompt    String?
  // Prompt de ATENDIMENTO ao cliente (numeros nao cadastrados).
  clientPrompt      String?
  lastConnectedAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
}

// Numeros autorizados a ALIMENTAR o sistema desta assinatura pela IA (operadores).
model WhatsappContact {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String? // vinculo opcional com um User (vet responsavel dos registros)
  name      String
  phone     String // apenas digitos, com DDI
  role      String   @default("WORKER") // OWNER, VET, WORKER
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages WhatsappMessage[]

  @@unique([tenantId, phone])
  @@index([tenantId, active])
}

// Log de mensagens (auditoria + memoria curta por telefone + inbox humano).
model WhatsappMessage {
  id        String           @id @default(cuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId String?
  contact   WhatsappContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  phone     String // apenas digitos
  pushName  String? // nome do perfil WhatsApp (para clientes nao cadastrados)
  direction String // IN, OUT
  actor     String           @default("CONTACT") // CONTACT, AI, HUMAN, SYSTEM
  kind      String           @default("TEXT") // TEXT, AUDIO, SYSTEM
  content   String
  toolCalls Json?
  readAt    DateTime? // controle de nao-lidas no inbox
  createdAt DateTime         @default(now())

  @@index([tenantId, phone, createdAt])
  @@index([tenantId, createdAt])
}
